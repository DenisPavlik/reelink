# Copy to .env.local and fill in real values. Never commit .env.local.

# OpenAI — used for GPT-4o script generation, tts-1-hd voice, and whisper-1 captions.
OPENAI_API_KEY=sk-proj-...

# Vercel Blob — used for per-scene mp3 storage (free 1 GB tier).
# Generated via `vercel env pull` after linking the project, or from the dashboard.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Upstash Redis — used for the kill-switch counter and per-IP rate limit.
# Sign up at https://upstash.com (free tier, no card required), create a Redis database,
# copy the REST URL + REST Token.
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# Kill-switch admin reset token — any random string. Used to authenticate the
# POST /api/admin/reset endpoint that zeroes the spend counter.
ADMIN_RESET_TOKEN=replace-with-a-long-random-string

# Optional. Discord/Slack webhook URL for budget alerts ($10 warn, $14 critical).
# Leave unset for MVP — alerts fall back to console.warn, which Vercel log drains pick up.
# ALERT_WEBHOOK_URL=

# Remotion Lambda — created in Step 7 via `npx remotion lambda functions deploy`
# and `npx remotion lambda sites create`. Plug the function name and serve URL here.
REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-...
REMOTION_SERVE_URL=https://remotionlambda-...s3.amazonaws.com/sites/reelink/index.html

# AWS — credentials for the IAM user that Remotion Lambda uses (Lambda + S3 permissions).
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
